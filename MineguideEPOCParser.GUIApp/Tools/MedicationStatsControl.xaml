<UserControl x:Class="MineguideEPOCParser.GUIApp.Tools.MedicationStatsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MineguideEPOCParser.GUIApp"
             xmlns:tools="clr-namespace:MineguideEPOCParser.Core.Tools;assembly=MineguideEPOCParser.Core"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" Content="Input CSV files:" VerticalAlignment="Center" />
            <TextBox Grid.Column="2" x:Name="InputFileTextBox" VerticalAlignment="Center" HorizontalAlignment="Stretch" />
            <Button Grid.Column="4" x:Name="BrowseButton" Content="Browse" Click="BrowseButton_Click" Padding="10,2" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="15" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0" x:Name="CalculateButton" Content="Calculate Stats" Click="CalculateButton_Click" HorizontalAlignment="Center" Padding="20,5" />

            <Grid x:Name="ResultsGrid" Grid.Row="2" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Evaluation Mode & Show/Hide percentages -->
                <StackPanel Orientation="Horizontal" Grid.Row="0">
                    <Label Content="Evaluation Mode:" FontWeight="Bold" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="0" Grid.Column="2" Margin="10 0 20 0" x:Name="EvaluationModeComboBox" SelectionChanged="EvaluationModeComboBox_SelectionChanged" VerticalAlignment="Center">
                        <ComboBoxItem Content="Strict (Exact matches only)" IsSelected="True" />
                        <ComboBoxItem Content="Relaxed (Exact + Fuzzy matches)" />
                    </ComboBox>

                    <CheckBox Grid.Row="0" Grid.Column="12" Grid.ColumnSpan="3" x:Name="ShowPercentagesCheckBox" Content="Show percentages" VerticalAlignment="Center" Checked="ShowPercentagesCheckBox_CheckedChanged" Unchecked="ShowPercentagesCheckBox_CheckedChanged" />
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Column 1: Counts -->
                    <Label Grid.Row="2" Grid.Column="0" Content="TP (Exact):" FontWeight="Bold" />
                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="TPTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="4" Grid.Column="0" Content="TP* (Partial):" FontWeight="Bold" />
                    <TextBox Grid.Row="4" Grid.Column="2" x:Name="TPStarTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="6" Grid.Column="0" Content="TP (Relaxed):" ToolTip="Relaxed = Exact + Partial" FontWeight="Bold" />
                    <TextBox Grid.Row="6" Grid.Column="2" x:Name="TPExactPlusFuzzyTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="8" Grid.Column="0" Content="FP:" FontWeight="Bold" />
                    <TextBox Grid.Row="8" Grid.Column="2" x:Name="FPTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="10" Grid.Column="0" Content="FN:" FontWeight="Bold" />
                    <TextBox Grid.Row="10" Grid.Column="2" x:Name="FNTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <!-- Column 2: Metrics -->
                    <Label Grid.Row="2" Grid.Column="4" Content="Precision:" FontWeight="Bold" />
                    <TextBox Grid.Row="2" Grid.Column="6" x:Name="PrecisionTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="8" x:Name="PrecisionPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="4" Grid.Column="4" Content="Recall:" FontWeight="Bold" />
                    <TextBox Grid.Row="4" Grid.Column="6" x:Name="RecallTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="8" x:Name="RecallPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="6" Grid.Column="4" Content="F1-Score:" FontWeight="Bold" />
                    <TextBox Grid.Row="6" Grid.Column="6" x:Name="F1ScoreTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="6" Grid.Column="8" x:Name="F1ScorePercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <!-- Column 3: Detailed Error Breakdown (part 1) -->
                    <Label Grid.Row="2" Grid.Column="10" Content="Boundary errors:" FontWeight="Bold" ToolTip="It partially extracted the medication (TP*) but didn't precisely do it" />
                    <TextBox Grid.Row="2" Grid.Column="12" x:Name="BoundaryErrorsTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="14" x:Name="BoundaryErrorsPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="4" Grid.Column="10" Content="- Under-extractions:" FontWeight="Bold" ToolTip="Boundary Error: Extracted less than the gold standard" />
                    <TextBox Grid.Row="4" Grid.Column="12" x:Name="UnderExtractionsTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="14" x:Name="UnderExtractionsPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="6" Grid.Column="10" Content="- Over-extractions:" FontWeight="Bold" ToolTip="Boundary Error: Extracted more than the gold standard" />
                    <TextBox Grid.Row="6" Grid.Column="12" x:Name="OverExtractionsTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="6" Grid.Column="14" x:Name="OverExtractionsPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="8" Grid.Column="10" Content="- Entity merging errors:" FontWeight="Bold" ToolTip="Boundary Error: Extracted multiple medications as a single combined one" />
                    <TextBox Grid.Row="8" Grid.Column="12" x:Name="EntityMergingErrorsTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="8" Grid.Column="14" x:Name="EntityMergingErrorsPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <!-- Column 4: Detailed Error Breakdown (part 2) -->
                    <Label Grid.Row="2" Grid.Column="16" Content="Total hallucinations:" FontWeight="Bold" ToolTip="All hallucinations (morphological + gen. typos)" />
                    <TextBox Grid.Row="2" Grid.Column="18" x:Name="HallucinationsErrorTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="20" x:Name="HallucinationsPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="4" Grid.Column="16" Content="- Morph. hallucinations:" FontWeight="Bold" ToolTip="Hallucinations: Morphological hallucinations (FP without match in text)" />
                    <TextBox Grid.Row="4" Grid.Column="18" x:Name="MorphHallucinationsErrorTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="20" x:Name="MorphHallucinationsPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="6" Grid.Column="16" Content="- Gen. typos:" FontWeight="Bold" ToolTip="Hallucinations: Generative Typos (TP* without match in text)" />
                    <TextBox Grid.Row="6" Grid.Column="18" x:Name="GenTyposErrorTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="6" Grid.Column="20" x:Name="GenTyposPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />

                    <Label Grid.Row="8" Grid.Column="16" Content="Semantic Ambiguities:" FontWeight="Bold" ToolTip="Contextual Errors / Non-Pharmacological Entities (FP with match in text)" />
                    <TextBox Grid.Row="8" Grid.Column="18" x:Name="SemanticAmbiguitiesTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="8" Grid.Column="20" x:Name="SemanticAmbiguitiesPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" Visibility="Collapsed" />
                </Grid>

                <!-- Details DataGrid -->
                <Expander Grid.Row="4" Header="Details" IsExpanded="False" Margin="0,10,0,0" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Label x:Name="TotalMedicationsCountLabel" Content="Medications: 0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,20,0" />
                            <Label x:Name="TotalReportsCountLabel" Content="Reports: 0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,20,0" />
                            <Label Content="Filter by Result:" VerticalAlignment="Center" />
                            <ComboBox x:Name="ResultFilterComboBox" MinWidth="80" MaxWidth="150" SelectionChanged="FilterChanged" Margin="5,0,20,0">
                                <ComboBoxItem Content="All" IsSelected="True" />
                                <ComboBoxItem Content="TP" />
                                <ComboBoxItem Content="TP*" />
                                <ComboBoxItem Content="FP" />
                                <ComboBoxItem Content="FN" />
                                <ComboBoxItem Content="Morph. Hallucination" Tag="{x:Static tools:ErrorType.MorphologicalHallucination}" />
                                <ComboBoxItem Content="Gen. Typo" Tag="{x:Static tools:ErrorType.GenerativeTypo}" />
                                <ComboBoxItem Content="Semantic Ambiguity" Tag="{x:Static tools:ErrorType.SemanticAmbiguity}" />
                                <ComboBoxItem Content="Under-extraction" Tag="{x:Static tools:ErrorType.UnderExtraction}" />
                                <ComboBoxItem Content="Over-extraction" Tag="{x:Static tools:ErrorType.OverExtraction}" />
                                <ComboBoxItem Content="Entity Merging Error" Tag="{x:Static tools:ErrorType.EntityMerging}" />
                            </ComboBox>

                            <Label Content="Medication:" VerticalAlignment="Center" />
                            <TextBox x:Name="MedicationFilterTextBox" MinWidth="100" MaxWidth="200" TextChanged="FilterChanged" VerticalAlignment="Center" />
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="DetailsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True" VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Report #" Binding="{Binding ReportNumber}" Width="Auto" />
                                <DataGridTextColumn Header="Medication" Binding="{Binding Medication}" Width="Auto" />
                                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="Auto" />
                                <DataGridTextColumn Header="Start Index" Binding="{Binding StartIndex}" Width="Auto" />
                                <DataGridTextColumn Header="Match In Text" Binding="{Binding MatchInText}" Width="Auto" />
                                <DataGridTextColumn Header="Error Type" Binding="{Binding Error}" Width="Auto" />
                                <DataGridTextColumn Header="Corrected Med." Binding="{Binding CorrectedMedication}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Expander>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
