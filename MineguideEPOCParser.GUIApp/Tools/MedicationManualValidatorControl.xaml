<UserControl x:Class="MineguideEPOCParser.GUIApp.Tools.MedicationManualValidatorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MineguideEPOCParser.GUIApp"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             DataContext="{Binding RelativeSource={RelativeSource Self}}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <RichTextBox Grid.Row="0" x:Name="MyRichTextBox" IsDocumentEnabled="True" IsReadOnly="True" />
        <DockPanel Grid.Row="0" Grid.Column="1" Margin="10">
            <TextBlock x:Name="MyWebViewLoadingText" DockPanel.Dock="Top" Text="Loading SNOMED..." />
            <wv2:WebView2 x:Name="MyWebView" Source="https://snomedsns.es/search" Margin="10" NavigationCompleted="OnNavigationCompleted" />
        </DockPanel>

        <!-- Progress bar, cancel button and log viewer -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Progress bar -->
            <ProgressBar Grid.Column="0" x:Name="ProgressBar" Height="20" VerticalAlignment="Center" HorizontalAlignment="Stretch" />

            <!-- Progress percentage text -->
            <TextBlock Grid.Column="2" x:Name="ProgressPercentageTextBlock" Text="0%" VerticalAlignment="Center" HorizontalAlignment="Center" />

            <!-- Progress rows processed text -->
            <TextBlock Grid.Column="4" x:Name="ProgressRowsProcessedTextBlock" Text="Rows processed: 0" HorizontalAlignment="Left" />
        </Grid>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button x:Name="BtnLoad" Content="Load" ToolTip="Load medications to validate. (Keybind: Ctrl+L)" Margin="5" Click="LoadMedications" IsEnabled="{Binding IsNotParsing}" />
            <Button x:Name="BtnBack" Content="Back" ToolTip="Go back to the previous report. (Keybind: B)" Margin="5" Click="OnUserRequestedBack" IsEnabled="{Binding IsParsing}" />
            <Button x:Name="BtnTrue" Content="True" ToolTip="Mark selected text or medication as True Positive (TP) if detected by the LLM, or as False Negative (FN) if not. (Keybind: T)" Margin="5" Click="OnTrueMedicationClicked" IsEnabled="{Binding IsParsing}" />
            <Button x:Name="BtnFalse" Content="False" ToolTip="Mark selected text or medication as False Positive (FP). (Keybind: F)" Margin="5" Click="OnFalseMedicationClicked" IsEnabled="{Binding IsParsing}" />
            <Button x:Name="BtnCorrect" Content="Correct" ToolTip="Correct the medication name from a marked medication. Useful for correcting mispellings (both human or LLM induced) (Keybind: C)" Margin="5" Click="OnCorrectMedicationClicked" IsEnabled="{Binding IsParsing}" />
            <Button x:Name="BtnNext" Content="Next" ToolTip="Go to the next report, or finish the validation if it's the last one. (Keybind: N)" Margin="5" Click="OnUserFinishedMedicationValidation" IsEnabled="{Binding IsParsing}" />
            <Button x:Name="BtnStop" Content="Stop" ToolTip="Save the current progress and stop the validation to resume it later. (Keybind: Ctrl+Shift+S)" Margin="5" Click="OnStopMedicationValidation" IsEnabled="{Binding IsParsing}" />
            <Button x:Name="BtnCancel" Content="Cancel" ToolTip="Cancel the validation without saving any changes. (Keybind: Ctrl+Alt+C)" Margin="5" Click="OnCancelMedicationValidation" IsEnabled="{Binding IsParsing}" />
        </StackPanel>
    </Grid>
</UserControl>
