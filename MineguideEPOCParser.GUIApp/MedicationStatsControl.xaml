<UserControl x:Class="MineguideEPOCParser.GUIApp.MedicationStatsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MineguideEPOCParser.GUIApp"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <Label Grid.Column="0" Content="Input CSV file:" VerticalAlignment="Center" />
            <TextBox Grid.Column="2" x:Name="InputFileTextBox" VerticalAlignment="Center" />
            <Button Grid.Column="4" x:Name="BrowseButton" Content="Browse" Click="BrowseButton_Click" Padding="10,2" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0" x:Name="CalculateButton" Content="Calculate Stats" Click="CalculateButton_Click" HorizontalAlignment="Center" Padding="20,5" />

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="ResultsGrid" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Counts -->
                    <Label Grid.Row="0" Grid.Column="0" Content="TP (Exact):" FontWeight="Bold" />
                    <TextBox Grid.Row="0" Grid.Column="2" x:Name="TPTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="2" Grid.Column="0" Content="TP* (Fuzzy):" FontWeight="Bold" />
                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="TPStarTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="4" Grid.Column="0" Content="FP:" FontWeight="Bold" />
                    <TextBox Grid.Row="4" Grid.Column="2" x:Name="FPTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="6" Grid.Column="0" Content="FN:" FontWeight="Bold" />
                    <TextBox Grid.Row="6" Grid.Column="2" x:Name="FNTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="8" Grid.Column="0" Content="Hallucinations:" FontWeight="Bold" />
                    <TextBox Grid.Row="8" Grid.Column="2" x:Name="HallucinationsTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <!-- Metrics -->
                    <Label Grid.Row="0" Grid.Column="4" Content="Precision:" FontWeight="Bold" />
                    <TextBox Grid.Row="0" Grid.Column="6" x:Name="PrecisionTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="8" x:Name="PrecisionPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="2" Grid.Column="4" Content="Recall:" FontWeight="Bold" />
                    <TextBox Grid.Row="2" Grid.Column="6" x:Name="RecallTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="8" x:Name="RecallPercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" />

                    <Label Grid.Row="4" Grid.Column="4" Content="F1-Score:" FontWeight="Bold" />
                    <TextBox Grid.Row="4" Grid.Column="6" x:Name="F1ScoreTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                    <TextBox Grid.Row="4" Grid.Column="8" x:Name="F1ScorePercentageTextBox" IsReadOnly="True" VerticalAlignment="Center" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
